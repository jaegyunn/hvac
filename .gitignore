# --- Model checkpoints ---
# Keep checkpoint outputs local by default; commit models/.gitkeep so the folder exists.
# Small .pt files under 10 MB can still be committed intentionally with git add -f.
models/*
!models/.gitkeep

# --- Notebooks ---
.ipynb_checkpoints/

