# --- Model checkpoints ---
# Keep checkpoint outputs local by default; commit models/.gitkeep so the folder exists.
# Small .pt files under 10 MB can still be committed intentionally with git add -f.
models/*
!models/.gitkeep

# --- Notebooks ---
.ipynb_checkpoints/

# --- Editors / OS ---
.vscode/
.idea/
.matplotlib-cache/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- AI agent instructions (local only) ---
AGENTS.md
CLAUDE.md

# --- Tracked artifacts (allow specific files despite earlier excludes) ---
# ROBOD dataset (small enough to commit, ~14MB total)
!data/
!data/raw/
!data/raw/ROBOD/
!data/raw/ROBOD/**
# Trained model checkpoints used by the demo (each <300KB)
!models/lstm_robod_room2.pt
!models/lstm_robod_multiroom.pt
!models/ppo_room2.zip
